VITE_OPENAI_API_KEY=

# Use the same Strava app credentials as production for predictable local testing.
VITE_STRAVA_CLIENT_ID=
VITE_STRAVA_CLIENT_SECRET=

# Optional if you want to override built-in defaults.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: set a dedicated Supabase app user for localhost testing.
# If omitted, the app falls back to runningcoach@example.com / runningcoach123.
VITE_SUPABASE_APP_USER_EMAIL=
VITE_SUPABASE_APP_USER_PASSWORD=
